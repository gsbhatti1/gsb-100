# ───────────────────────────────────────────────────────────────
# GSB-100 — environment
# Copy to .env and fill in. Never commit .env.
# Credentials live in Bitwarden; this file is the recovery map.
# ───────────────────────────────────────────────────────────────

# ⚠  SECURITY NOTE  ⚠
# A prior version of this file contained real secrets. They are
# still in git history — ROTATE THEM NOW:
#   - Gmail app password       → myaccount.google.com → App passwords
#   - Backblaze Key ID + key   → secure.backblaze.com → App Keys
#   - WhatsApp API key         → regenerate in provider dashboard
# Then fill the new values into your local .env (never this file).

# Telegram - preferred alert channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Your phone (T-Mobile) - optional SMS fallback via email gateway
YOUR_PHONE=+15555555555
TMOBILE_GATEWAY=5555555555@tmomail.net

# Gmail - optional. Used for email and SMS fallback
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Backblaze B2 — nightly backup
BACKBLAZE_KEY_ID=
BACKBLAZE_APP_KEY=
BACKBLAZE_BUCKET=gsb-100-backup

# Storage paths — Linux default; Windows dev override (e.g. C:/gsb-100/data/brain.db)
DB_PATH=/opt/gsb-100/data/brain.db
DB_DIR=/opt/gsb-100/data

# Ollama (local AI)
OLLAMA_HOST=http://localhost:11434
# Windows dev: keep MODEL_FAST and MODEL_REASON the same to avoid model-swap thrash.
MODEL_FAST=llama3.2:3b
MODEL_FAST_BACKUP=deepseek-r1:32b
MODEL_REASON=deepseek-r1:32b
MODEL_EMBED=nomic-embed-text
# Back-compat — used by local-ai-chat.js
OLLAMA_MODEL=deepseek-r1:32b

# Chroma (vector memory)
CHROMA_HOST=http://localhost:8000
VECTOR_MEMORY_ENABLED=1

# Langfuse (observability) — optional but recommended
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# n8n
N8N_PORT=5678
N8N_BASIC_AUTH_USER=you@example.com
N8N_BASIC_AUTH_PASSWORD=change-me

# Cleanup knobs
OLLAMA_CLEANUP=0

# Legacy (kept so existing scripts don't break)
WHATSAPP_PHONE=
WHATSAPP_APIKEY=
